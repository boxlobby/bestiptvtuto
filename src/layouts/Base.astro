---
interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description = 'Best IPTV tutorials, setup guides and how-tos for all devices.', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | BestIPTVTuto</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  {image && <meta property="og:image" content={image} />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta name="twitter:card" content="summary_large_image" />
</head>
<body class="bg-gray-50 text-gray-900 font-sans">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-brand">📺 BestIPTVTuto</a>
      <nav class="hidden md:flex gap-6 text-sm font-medium text-gray-600">
        <a href="/" class="hover:text-brand transition">Home</a>
        <a href="/blog" class="hover:text-brand transition">Tutorials</a>
        <a href="/devices" class="hover:text-brand transition">Devices</a>
      </nav>
    </div>
  </header>

  <!-- Main -->
  <main class="max-w-5xl mx-auto px-4 py-10">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-white border-t border-gray-200 mt-20">
    <div class="max-w-5xl mx-auto px-4 py-8 text-sm text-gray-500 flex flex-col md:flex-row justify-between gap-4">
      <p>© {new Date().getFullYear()} BestIPTVTuto — All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/sitemap-index.xml" class="hover:text-brand">Sitemap</a>
        <a href="/privacy" class="hover:text-brand">Privacy</a>
      </div>
    </div>
  </footer>
</body>
</html>
