---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Base title={post.data.title} description={post.data.description}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-blue-600">Home</a> /
      <a href="/blog" class="hover:text-blue-600">Tutorials</a> /
      <span>{post.data.title}</span>
    </nav>
    <h1 class="text-4xl font-bold text-gray-900 mb-4">{post.data.title}</h1>
    <p class="text-gray-500 mb-8">By {post.data.author} • {post.data.date}</p>
    <div class="prose prose-lg prose-blue max-w-none">
      <Content />
    </div>
  </article>
</Base>
